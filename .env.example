### Application Code Path
APP_CODE_PATH_HOST=../
APP_CODE_PATH_CONTAINER=/var/www

### Host user IDs — match with your host user: run `id -u` and `id -g`
PUID=1000
PGID=1000

### Drivers
VOLUMES_DRIVER=local
NETWORKS_DRIVER=bridge

### PHP Versions (choose which to use per project in nginx site configs)
# Available: php56, php74, php81, php84

### Nginx
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

### HAProxy
HAPROXY_HTTP_PORT=80
HAPROXY_HTTPS_PORT=8443
HAPROXY_STATS_PORT=1936
HAPROXY_STATS_USER=admin
HAPROXY_STATS_PASSWORD=secret

### MySQL
MYSQL_VERSION=8.0
MYSQL_DATABASE=laravel
MYSQL_USER=laravel
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306
MYSQL_ENTRYPOINT_INITDB=./mysql/docker-entrypoint-initdb.d

### Redis
REDIS_PORT=6379

### PHP FPM Ports (internal, used by nginx upstream)
PHP56_FPM_PORT=9056
PHP74_FPM_PORT=9074
PHP81_FPM_PORT=9081
PHP84_FPM_PORT=9084

### Supervisor
SUPERVISOR_LOG_PATH=./logs/supervisor
